# MLOps Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mlops

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow/mlflow.db
MLFLOW_DEFAULT_ARTIFACT_ROOT=./mlruns

# Model Configuration
MODEL_NAME=sentiment-classifier
MODEL_STAGE=Production
MODEL_REGISTRY_URI=http://localhost:5000

# Training Configuration
LEARNING_RATE=2e-5
BATCH_SIZE=32
NUM_EPOCHS=3
RANDOM_SEED=42

# Serving Configuration
API_PORT=8000
API_HOST=0.0.0.0
DEBUG_MODE=False

# Drift Detection
DRIFT_CHECK_INTERVAL=100  # Check every N inferences
DRIFT_KS_THRESHOLD=0.05
DRIFT_PSI_THRESHOLD=0.1

# Monitoring & Alerts
ALERT_RETENTION_DAYS=30
LOG_LEVEL=INFO
LOG_FILE=logs/mlops.log

# Optional: Cloud Storage (for future scaling)
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# S3_BUCKET=your-bucket
# GCP_PROJECT_ID=your-project
# GCP_CREDENTIALS_PATH=/path/to/credentials.json
